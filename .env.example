# ── AI ────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Auth ──────────────────────────────────────────────────────
# Generate a strong random string: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# ── Supabase ──────────────────────────────────────────────────
# Find these in your Supabase project: Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
# Local:      ALLOWED_ORIGINS=http://localhost:8000
# Production: ALLOWED_ORIGINS=https://your-app.onrender.com
ALLOWED_ORIGINS=http://localhost:8000

# ── Google Sign-In (optional) ─────────────────────────────────
# Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
# App type: Web application
# Add BOTH URIs as Authorized redirect URIs in Google Console:
#   http://localhost:8000/api/auth/google/callback          (local)
#   https://your-app.onrender.com/api/auth/google/callback  (production)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Local default — override in production:
# GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
# GOOGLE_REDIRECT_URI=https://your-app.onrender.com/api/auth/google/callback

# ── Strava Integration (optional) ────────────────────────────
# Create an API application at https://www.strava.com/settings/api
# Authorization Callback Domain: your-app.onrender.com (production) or localhost (local)
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret
# Local default — override in production:
# STRAVA_REDIRECT_URI=http://localhost:8000/api/integrations/strava/callback
# STRAVA_REDIRECT_URI=https://your-app.onrender.com/api/integrations/strava/callback
# A secret string YOU choose — used to verify Strava webhook subscription
STRAVA_WEBHOOK_VERIFY_TOKEN=takbo_strava_verify
